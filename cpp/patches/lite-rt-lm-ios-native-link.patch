+# Unless required by applicable law or agreed to in writing, software
+# distributed under the License is distributed on an "AS IS" BASIS,
+# WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+# See the License for the specific language governing permissions and
+# limitations under the License.
+
+load("@build_bazel_apple_support//test:linking_support.bzl", "link_multi_arch_static_library")
+load("@build_bazel_apple_support//test:transitions.bzl", "apple_platform_split_transition")
+
+def _apple_static_library_impl(ctx):
+    if not hasattr(apple_common.platform_type, ctx.attr.platform_type):
+        fail("Unsupported platform type \"{}\"".format(ctx.attr.platform_type))
+
+    link_result = link_multi_arch_static_library(
+        ctx = ctx,
+        cc_toolchains = ctx.split_attr._cc_toolchain_forwarder,
+    )
+    output_library = ctx.actions.declare_file("{}_lipo.a".format(ctx.label.name))
+    libraries = [output.library for output in link_result.outputs]
+
+    if len(libraries) > 1:
+        xcode_config = ctx.attr._xcode_config[apple_common.XcodeVersionConfig]
+        apple_env = {}
+        apple_env.update(apple_common.apple_host_system_env(xcode_config))
+        apple_env.update(
+            apple_common.target_apple_env(
+                xcode_config,
+                ctx.fragments.apple.single_arch_platform,
+            ),
+        )
+        args = ctx.actions.args()
+        args.add("-create")
+        args.add_all(libraries)
+        args.add("-output", output_library)
+        ctx.actions.run(
+            arguments = [args],
+            env = apple_env,
+            executable = "/usr/bin/lipo",
+            execution_requirements = xcode_config.execution_info(),
+            inputs = libraries,
+            outputs = [output_library],
+        )
+    else:
+        ctx.actions.symlink(
+            target_file = libraries[0],
+            output = output_library,
+        )
+
+    return [
+        DefaultInfo(files = depset([output_library])),
+        link_result.output_groups,
+    ]
+
+apple_static_library = rule(
+    _apple_static_library_impl,
+    attrs = {
+        "_child_configuration_dummy": attr.label(
+            cfg = apple_platform_split_transition,
+            default = Label("@bazel_tools//tools/cpp:current_cc_toolchain"),
+        ),
+        "_xcode_config": attr.label(
+            default = configuration_field(
+                fragment = "apple",
+                name = "xcode_config_label",
+            ),
+        ),
+        "additional_linker_inputs": attr.label_list(
+            allow_files = True,
+        ),
+        "avoid_deps": attr.label_list(
+            cfg = apple_platform_split_transition,
+            default = [],
+        ),
+        "deps": attr.label_list(
+            cfg = apple_platform_split_transition,
+            providers = [CcInfo],
+        ),
+        "linkopts": attr.string_list(),
+        "platform_type": attr.string(mandatory = True),
+        "minimum_os_version": attr.string(mandatory = True),
+        "_cc_toolchain_forwarder": attr.label(
+            cfg = apple_platform_split_transition,
+            default = Label("//:apple_cc_toolchain_forwarder"),
+        ),
+        "_allowlist_function_transition": attr.label(
+            default = Label("@bazel_tools//tools/allowlists/function_transition_allowlist"),
+        ),
+    },
+    fragments = ["apple", "objc", "cpp"],
+)
