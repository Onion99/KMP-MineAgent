startup --output_user_root=G:/_b
build --action_env=BAZEL_VC="C:/Program Files (x86)/Microsoft Visual Studio/2022/BuildTools/VC"
build --repo_env=BAZEL_VC="C:/Program Files (x86)/Microsoft Visual Studio/2022/BuildTools/VC"

# MSVC-only UTF-8 flags. Do not set these as global target copts: Android NDK
# clang treats /utf-8 as an input file and fails during cross-compilation.
build:msvc_target_utf8 --copt=/utf-8
build:msvc_target_utf8 --cxxopt=/utf-8
build:msvc_target_utf8 --host_copt=/utf-8
build:msvc_target_utf8 --host_cxxopt=/utf-8
build:win_host --host_copt=/utf-8
build:win_host --host_cxxopt=/utf-8
